<!-- views/auth/login.ejs -->
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Rumah Sakit Medika</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body { 
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #4f46e5 0%, rgb(124, 58, 237) 50%, #1e1b4b 100%);
            padding: 2rem;
        }
        .auth-card {
            background: rgba(255,255,255,0.98);
            backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            max-width: 440px;
            width: 100%;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            animation: fadeInUp 0.6s ease;
            border: 1px solid rgba(255,255,255,0.1);
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .auth-card .auth-logo {
            text-align: center;
            margin-bottom: 2rem;
        }
        .auth-card .auth-logo .logo-icon {
            width: 75px;
            height: 75px;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            color: white;
            box-shadow: 0 15px 30px rgba(79,70,229,0.3);
        }
        .auth-card .auth-title {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0.3rem;
            color: #0f172a;
        }
        .auth-card .auth-subtitle {
            text-align: center;
            color: #64748b;
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }
        .auth-card .form-group {
            margin-bottom: 1.25rem;
        }
        .auth-card .form-group label {
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 0.4rem;
            display: block;
            font-size: 0.9rem;
        }
        .auth-card .form-group .input-group {
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid #e2e8f0;
            transition: all 0.3s ease;
            background: white;
        }
        .auth-card .form-group .input-group:focus-within {
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79,70,229,0.1);
        }
        .auth-card .form-group .input-group-text {
            background: transparent;
            border: none;
            color: #94a3b8;
            padding: 0 0 0 1rem;
        }
        .auth-card .form-group .form-control {
            border: none;
            padding: 0.8rem 1rem;
            font-size: 0.95rem;
            background: transparent;
        }
        .auth-card .form-group .form-control:focus {
            box-shadow: none;
        }
        .auth-card .btn {
            width: 100%;
            padding: 0.9rem;
            font-size: 1rem;
            justify-content: center;
            border-radius: 12px;
            font-weight: 700;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: white;
            border: none;
            transition: all 0.3s ease;
        }
        .auth-card .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(79,70,229,0.3);
        }
        .auth-card .auth-footer {
            text-align: center;
            margin-top: 1.5rem;
            color: #64748b;
            font-size: 0.9rem;
        }
        .auth-card .auth-footer a {
            color: #4f46e5;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
        }
        .auth-card .auth-footer a:hover {
            color: #7c3aed;
            text-decoration: underline;
        }
        .auth-card .demo-info {
            margin-top: 1.5rem;
            padding: 1rem 1.2rem;
            background: #f8fafc;
            border-radius: 12px;
            text-align: center;
            font-size: 0.85rem;
            color: #64748b;
            border: 1px dashed #e2e8f0;
        }
        .auth-card .demo-info strong {
            color: #0f172a;
        }
        .auth-card .demo-info code {
            background: #e2e8f0;
            padding: 0.15rem 0.6rem;
            border-radius: 4px;
            font-size: 0.8rem;
            color: #4f46e5;
        }
        .alert {
            border-radius: 12px;
            border: none;
            padding: 0.8rem 1rem;
            margin-bottom: 1.5rem;
        }
        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
            border-left: 4px solid #ef4444;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-logo">
            <div class="logo-icon">
                <i class="fas fa-heartbeat"></i>
            </div>
        </div>
        <h1 class="auth-title">Selamat Datang</h1>
        <p class="auth-subtitle">Silakan login untuk melanjutkan</p>
        
        <% if (locals.error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="email"><i class="fas fa-envelope text-primary me-2"></i> Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input type="email" class="form-control" id="email" name="email" 
                           placeholder="Masukkan email" required value="<%= locals.email || '' %>">
                </div>
            </div>
            
            <div class="form-group">
                <label for="password"><i class="fas fa-lock text-primary me-2"></i> Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" class="form-control" id="password" name="password" 
                           placeholder="Masukkan password" required>
                </div>
            </div>
            
            <button type="submit" class="btn">
                <i class="fas fa-sign-in-alt me-2"></i> Login
            </button>
        </form>
        
        <div class="auth-footer">
            Belum punya akun? <a href="/auth/register">Daftar sekarang</a>
        </div>
       
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>