<!-- views/dashboard/patient.ejs -->
<%
let body = `
<style>
    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 1.8rem 2rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07);
        transition: all 0.3s ease;
        text-align: center;
        height: 100%;
        border-left: 4px solid #4f46e5;
        position: relative;
        overflow: hidden;
    }
    .stat-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
    }
    .stat-card .stat-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .stat-card .stat-icon.primary { color: #4f46e5; }
    .stat-card .stat-icon.success { color: #10b981; }
    .stat-card .stat-icon.info { color: #06b6d4; }
    .stat-card .stat-number {
        font-size: 2.8rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
    }
    .stat-card .stat-label {
        font-size: 0.9rem;
        color: #64748b;
        font-weight: 500;
    }
    .stat-card .stat-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 0.8rem;
        color: #4f46e5;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }
    .stat-card .stat-link:hover { gap: 12px; }
    .stat-card.green { border-left-color: #10b981; }
    .stat-card.teal { border-left-color: #06b6d4; }
    .stat-card::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        opacity: 0.02;
        border-radius: 50%;
        transition: all 0.3s ease;
    }
    .stat-card:hover::after { transform: scale(1.5); }
</style>

<!-- ========================================
PAGE HEADER
======================================== -->
<div class="page-header">
    <div>
        <h1><i class="fas fa-chart-pie"></i> Dashboard Pasien</h1>
        <p class="subtitle">Selamat datang, <strong>${user ? user.name : ''}</strong>! Kelola kesehatan Anda di sini.</p>
    </div>
    <div>
        <span class="badge bg-success px-4 py-2 rounded-pill">
            <i class="fas fa-user-check me-2"></i> Pasien Aktif
        </span>
    </div>
</div>

<!-- ========================================
WELCOME CARD
======================================== -->
<div class="card mb-4" style="background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); color: white;">
    <div class="card-body p-4">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 60px; height: 60px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem;">
                <i class="fas fa-user-circle"></i>
            </div>
            <div>
                <h4 class="mb-0 fw-bold">${user ? user.name : ''}</h4>
                <p class="mb-0 opacity-75"><i class="fas fa-envelope me-2"></i>${user ? user.email : ''}</p>
            </div>
            <div class="ms-auto">
                <span class="badge bg-white bg-opacity-20 px-4 py-2 rounded-pill">
                    <i class="fas fa-calendar-day me-2"></i> ${new Date().toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
            </div>
        </div>
    </div>
</div>

<!-- ========================================
STATISTICS CARDS
======================================== -->
<div class="row g-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon primary">
                <i class="fas fa-calendar-check"></i>
            </div>
            <div class="stat-number">${totalAppointments || 0}</div>
            <div class="stat-label">Janji Temu Saya</div>
            <a href="/appointments" class="stat-link">Lihat Semua <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card green">
            <div class="stat-icon success">
                <i class="fas fa-file-medical"></i>
            </div>
            <div class="stat-number">${totalRecords || 0}</div>
            <div class="stat-label">Rekam Medis Saya</div>
            <a href="/records" class="stat-link">Lihat Semua <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card teal">
            <div class="stat-icon info">
                <i class="fas fa-prescription"></i>
            </div>
            <div class="stat-number">${totalPrescriptions || 0}</div>
            <div class="stat-label">Resep Obat Saya</div>
            <a href="/prescriptions" class="stat-link">Lihat Semua <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</div>
`;
%>
<%- include('../layout', { title: 'Dashboard Pasien', body: body }) %>