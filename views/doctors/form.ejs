<!-- views/doctors/form.ejs -->
<!DOCTYPE html>
<html>
<head>
    <title><%= doctor ? 'Edit' : 'Tambah' %> Dokter</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-4">
        <h1><%= doctor ? 'Edit' : 'Tambah' %> Dokter</h1>
        
        <form action="<%= doctor ? '/doctors/edit/' + doctor.id : '/doctors/add' %>" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Nama Dokter</label>
                <input type="text" class="form-control" id="name" name="name" value="<%= doctor ? doctor.name : '' %>" required>
            </div>
            
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" value="<%= doctor ? doctor.email : '' %>" required>
            </div>
            
            <div class="mb-3">
                <label for="specialist" class="form-label">Spesialis</label>
                <input type="text" class="form-control" id="specialist" name="specialist" value="<%= doctor ? doctor.specialist : '' %>">
            </div>
            
            <div class="mb-3">
                <label for="phone" class="form-label">Telepon</label>
                <input type="text" class="form-control" id="phone" name="phone" value="<%= doctor ? doctor.phone : '' %>">
            </div>
            
            <div class="mb-3">
                <label for="schedule" class="form-label">Jadwal Praktek</label>
                <input type="text" class="form-control" id="schedule" name="schedule" value="<%= doctor ? doctor.schedule : '' %>" placeholder="Contoh: Senin-Jumat 08:00-16:00">
            </div>
            
            <button type="submit" class="btn btn-primary">Simpan</button>
            <a href="/doctors" class="btn btn-secondary">Batal</a>
        </form>
    </div>
</body>
</html>