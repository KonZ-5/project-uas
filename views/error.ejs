<!-- views/error.ejs -->
<%
let body = `
<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card text-center" style="max-width: 480px; width: 100%;">
        <div class="card-body p-5">
            <div class="mb-4">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #f59e0b;"></i>
            </div>
            <h2 class="mb-3 fw-bold">${title || 'Error'}</h2>
            <p class="text-muted mb-4">${message || 'Terjadi kesalahan'}</p>
            ${error && error.status ? `<p class="text-muted small">Status: ${error.status}</p>` : ''}
            <a href="/" class="btn btn-primary">
                <i class="fas fa-home"></i> Kembali ke Dashboard
            </a>
        </div>
    </div>
</div>
`;
%>
<%- include('layout', { title: title || 'Error', body: body }) %>