<!-- views/labs/index.ejs -->
<%
let body = `
<div class="page-header">
    <div>
        <h1><i class="fas fa-flask"></i> Hasil Laboratorium</h1>
        <p class="subtitle">Kelola semua hasil pemeriksaan laboratorium.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        ${user && (user.role === 'admin' || user.role === 'doctor') ? `
            <a href="/labs/upload" class="btn btn-primary">
                <i class="fas fa-upload"></i> Upload Hasil Lab
            </a>
        ` : ''}
        <a href="/dashboard/${user ? user.role : ''}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Kembali
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Pasien</th>
                        <th>Dokter</th>
                        <th>Nama File</th>
                        <th>Tanggal Upload</th>
                        <th style="text-align: center;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    ${labs && labs.length > 0 ? labs.map((lab, index) => `
                        <tr>
                            <td>${index + 1}</td>
                            <td><strong>${lab.patientName}</strong></td>
                            <td>${lab.doctorName || '-'}</td>
                            <td>
                                <a href="/uploads/${lab.fileName}" target="_blank" class="text-primary">
                                    <i class="fas fa-file-pdf me-1"></i> ${lab.originalName || lab.fileName}
                                </a>
                            </td>
                            <td>${lab.createdAt ? new Date(lab.createdAt).toLocaleDateString('id-ID') : '-'}</td>
                            <td style="text-align: center;">
                                ${user && (user.role === 'admin' || (user.role === 'doctor' && lab.doctorEmail === user.email)) ? `
                                    <a href="/labs/delete/${lab.id}" class="btn btn-danger btn-sm" 
                                       onclick="return confirm('Yakin ingin menghapus?')" title="Hapus">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                ` : '<span class="text-muted">-</span>'}
                            </td>
                        </tr>
                    `).join('') : `
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-flask"></i>
                                    <h5>Belum ada hasil laboratorium</h5>
                                    <p>Upload hasil laboratorium untuk pasien.</p>
                                    ${user && (user.role === 'admin' || user.role === 'doctor') ? `
                                        <a href="/labs/upload" class="btn btn-primary">
                                            <i class="fas fa-upload"></i> Upload Hasil Lab
                                        </a>
                                    ` : ''}
                                </div>
                            </td>
                        </tr>
                    `}
                </tbody>
            </table>
        </div>
    </div>
</div>
`;
%>
<%- include('../layout', { title: 'Hasil Laboratorium', body: body }) %>