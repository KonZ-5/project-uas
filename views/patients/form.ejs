<!-- views/patients/form.ejs -->
<!-- views/patients/form.ejs -->
<%
let body = `
<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card">
            <div class="card-header">
                <span>
                    <i class="fas ${patient ? 'fa-edit' : 'fa-user-plus'}"></i> 
                    ${patient ? 'Edit Pasien' : 'Tambah Pasien'}
                </span>
            </div>
            <div class="card-body">
                <!-- <form action="${patient ? '/patients/update/' + patient.id : '/patients/add'}" method="POST"> --><form action="${patient ? '/patients/edit/' + patient.id : '/patients/add'}" method="POST">
                    <div class="row">
                        <div class="col-12 form-group">
                            <label>Nama Lengkap <span class="required">*</span></label>
                            <input type="text" name="name" class="form-control" 
                                   placeholder="Masukkan nama lengkap" 
                                   value="${patient ? patient.name : ''}" required>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label>NIK <span class="required">*</span></label>
                            <input type="text" name="nik" class="form-control" 
                                   placeholder="Masukkan NIK" 
                                   value="${patient ? patient.nik : ''}" required>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label>Tanggal Lahir <span class="required">*</span></label>
                            <input type="date" name="birthDate" class="form-control" 
                                   value="${patient ? patient.birthDate : ''}" required>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label>Telepon <span class="required">*</span></label>
                            <input type="text" name="phone" class="form-control" 
                                   placeholder="Masukkan nomor telepon" 
                                   value="${patient ? patient.phone : ''}" required>
                        </div>
                        
                        <div class="col-md-6 form-group">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" 
                                   placeholder="Masukkan email" 
                                   value="${patient ? patient.email : ''}">
                        </div>
                        
                        <div class="col-12 form-group">
                            <label>Alamat</label>
                            <textarea name="address" class="form-control" 
                                      placeholder="Masukkan alamat lengkap" 
                                      rows="3">${patient ? patient.address : ''}</textarea>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Simpan
                        </button>
                        <a href="/patients" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
`;
%>
<%- include('../layout', { title: patient ? 'Edit Pasien' : 'Tambah Pasien', body: body }) %>