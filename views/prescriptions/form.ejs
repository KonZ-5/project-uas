<!-- views/prescriptions/form.ejs -->
<%
let body = `
<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card">
            <div class="card-header">
                <span>
                    <i class="fas ${prescription ? 'fa-edit' : 'fa-prescription'}"></i> 
                    ${prescription ? 'Edit Resep' : 'Tambah Resep'}
                </span>
            </div>
            <div class="card-body">
                <form action="${prescription ? '/prescriptions/update/' + prescription.id : '/prescriptions/add'}" method="POST">
                    <div class="form-group">
                        <label>Pasien <span class="required">*</span></label>
                        <select name="patientName" class="form-select" id="patientSelect" required>
                            <option value="">Pilih Pasien</option>
                            ${patients.map(patient => `
                                <option value="${patient.name}" data-email="${patient.email || ''}" 
                                    ${prescription && prescription.patientName === patient.name ? 'selected' : ''}>
                                    ${patient.name}
                                </option>
                            `).join('')}
                        </select>
                        <input type="hidden" id="patientEmail" name="patientEmail" 
                               value="${prescription ? prescription.patientEmail : ''}">
                    </div>

                    <div class="form-group">
                        <label>Nama Obat <span class="required">*</span></label>
                        <input type="text" name="medicine" class="form-control" 
                               value="${prescription ? prescription.medicine : ''}" 
                               placeholder="Masukkan nama obat" required>
                    </div>

                    <div class="form-group">
                        <label>Dosis <span class="required">*</span></label>
                        <input type="text" name="dosage" class="form-control" 
                               value="${prescription ? prescription.dosage : ''}" 
                               placeholder="Contoh: 2x sehari 1 tablet" required>
                    </div>

                    <div class="form-group">
                        <label>Keterangan</label>
                        <textarea name="notes" class="form-control" rows="3" 
                                  placeholder="Tambahkan keterangan tambahan">${prescription ? prescription.notes : ''}</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Simpan
                        </button>
                        <a href="/prescriptions" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const patientSelect = document.getElementById('patientSelect');
        const patientEmail = document.getElementById('patientEmail');
        
        function setPatientEmail() {
            const option = patientSelect.options[patientSelect.selectedIndex];
            patientEmail.value = option.getAttribute('data-email') || '';
        }
        
        setPatientEmail();
        patientSelect.addEventListener('change', setPatientEmail);
    });
</script>
`;
%>
<%- include('../layout', { title: prescription ? 'Edit Resep' : 'Tambah Resep', body: body }) %>