<!-- views/prescriptions/index.ejs -->
<%
let body = `
<div class="page-header">
    <div>
        <h1><i class="fas fa-prescription"></i> Resep Obat</h1>
        <p class="subtitle">Kelola semua resep obat pasien.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        ${user && (user.role === 'admin' || user.role === 'doctor') ? `
            <a href="/prescriptions/add" class="btn btn-primary">
                <i class="fas fa-plus"></i> Tambah Resep
            </a>
        ` : ''}
        <a href="/dashboard/${user ? user.role : ''}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Kembali
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Pasien</th>
                        <th>Dokter</th>
                        <th>Nama Obat</th>
                        <th>Dosis</th>
                        <th>Keterangan</th>
                        <th style="text-align: center;">Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    ${prescriptions && prescriptions.length > 0 ? prescriptions.map((item, index) => `
                        <tr>
                            <td>${index + 1}</td>
                            <td><strong>${item.patientName}</strong></td>
                            <td>${item.doctorName}</td>
                            <td><span class="badge-custom badge-info-custom">${item.medicine}</span></td>
                            <td>${item.dosage}</td>
                            <td>${item.notes || '-'}</td>
                            <td style="text-align: center;">
                                ${user && (user.role === 'admin' || (user.role === 'doctor' && item.doctorEmail === user.email)) ? `
                                    <div class="d-flex gap-1 justify-content-center">
                                        <a href="/prescriptions/edit/${item.id}" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="/prescriptions/delete/${item.id}" class="btn btn-danger btn-sm" onclick="return confirm('Yakin ingin menghapus?')" title="Hapus">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                ` : '<span class="text-muted">-</span>'}
                            </td>
                        </tr>
                    `).join('') : `
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-prescription-bottle"></i>
                                    <h5>Belum ada resep</h5>
                                    <p>Mulai buat resep untuk pasien.</p>
                                    ${user && (user.role === 'admin' || user.role === 'doctor') ? `
                                        <a href="/prescriptions/add" class="btn btn-primary">
                                            <i class="fas fa-plus"></i> Tambah Resep
                                        </a>
                                    ` : ''}
                                </div>
                            </td>
                        </tr>
                    `}
                </tbody>
            </table>
        </div>
    </div>
</div>
`;
%>
<%- include('../layout', { title: 'Resep Obat', body: body }) %>