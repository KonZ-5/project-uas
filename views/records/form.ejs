<!-- views/records/form.ejs -->
<%
let body = `
<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card">
            <div class="card-header">
                <span>
                    <i class="fas ${record && record.id ? 'fa-edit' : 'fa-file-medical'}"></i> 
                    ${record && record.id ? 'Edit Rekam Medis' : 'Tambah Rekam Medis'}
                </span>
            </div>
            <div class="card-body">
                <form action="${record && record.id ? '/records/update/' + record.id : '/records/add'}" method="POST">
                    <div class="form-group">
                        <label>Nama Pasien <span class="required">*</span></label>
                        <select name="patientName" class="form-select" required>
                            <option value="">Pilih Pasien</option>
                            ${patients.map(patient => `
                                <option value="${patient.name}" ${record && record.patientName === patient.name ? 'selected' : ''}>
                                    ${patient.name}
                                </option>
                            `).join('')}
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Email Pasien <span class="required">*</span></label>
                        <input type="email" name="patientEmail" class="form-control" 
                               value="${record ? record.patientEmail : ''}" required>
                    </div>

                    <div class="form-group">
                        <label>Diagnosis <span class="required">*</span></label>
                        <textarea name="diagnosis" class="form-control" rows="3" required>${record ? record.diagnosis : ''}</textarea>
                    </div>

                    <div class="form-group">
                        <label>Pengobatan</label>
                        <textarea name="treatment" class="form-control" rows="3">${record ? record.treatment : ''}</textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Simpan
                        </button>
                        <a href="/records" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Kembali
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
`;
%>
<%- include('../layout', { title: record && record.id ? 'Edit Rekam Medis' : 'Tambah Rekam Medis', body: body }) %>