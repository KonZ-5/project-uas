<!-- views/statistics.ejs -->
<%
let body = `
<!-- ========================================
PAGE HEADER
======================================== -->
<div class="page-header">
    <div>
        <h1><i class="fas fa-chart-bar"></i> Statistik Rumah Sakit</h1>
        <p class="subtitle">Ringkasan data seluruh rumah sakit dalam satu tampilan.</p>
    </div>
</div>

<!-- ========================================
STATISTICS CARDS
======================================== -->
<div class="row g-4 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card blue text-center">
            <div class="stat-number" style="font-size: 2.5rem;">${doctorCount || 0}</div>
            <div class="stat-label"><i class="fas fa-user-md me-2"></i>Dokter</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card green text-center">
            <div class="stat-number" style="font-size: 2.5rem;">${patientCount || 0}</div>
            <div class="stat-label"><i class="fas fa-users me-2"></i>Pasien</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card yellow text-center">
            <div class="stat-number" style="font-size: 2.5rem;">${appointmentCount || 0}</div>
            <div class="stat-label"><i class="fas fa-calendar-check me-2"></i>Janji Temu</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card purple text-center">
            <div class="stat-number" style="font-size: 2.5rem;">${prescriptionCount || 0}</div>
            <div class="stat-label"><i class="fas fa-prescription me-2"></i>Resep</div>
        </div>
    </div>
</div>

<!-- ========================================
CHART
======================================== -->
<div class="card">
    <div class="card-header">
        <span><i class="fas fa-chart"></i> Grafik Statistik</span>
    </div>
    <div class="card-body">
        <canvas id="statChart" height="80"></canvas>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('statChart').getContext('2d');
    
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Dokter', 'Pasien', 'Janji Temu', 'Resep'],
            datasets: [{
                label: 'Jumlah Data',
                data: [${doctorCount || 0}, ${patientCount || 0}, ${appointmentCount || 0}, ${prescriptionCount || 0}],
                backgroundColor: [
                    'rgba(79, 70, 229, 0.8)',
                    'rgba(16, 185, 129, 0.8)',
                    'rgba(245, 158, 11, 0.8)',
                    'rgba(139, 92, 246, 0.8)'
                ],
                borderColor: [
                    '#4f46e5',
                    '#10b981',
                    '#f59e0b',
                    '#8b5cf6'
                ],
                borderWidth: 2,
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 }
                }
            }
        }
    });
</script>
`;
%>
<%- include('layout', { title: 'Statistik', body: body }) %>